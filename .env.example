# ============================================================
# ERP Base — environment variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local — it is gitignored.
# NEVER put SUPABASE_SERVICE_ROLE_KEY here with a real value.
# ============================================================

# --- Supabase (required) ------------------------------------
# Settings → API in your Supabase project dashboard
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-only: never expose this to the client or commit it
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- App URL (required for OAuth callbacks + invite links) --
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# --- Email (Resend) — resend.com ----------------------------
RESEND_API_KEY=re_your_key_here
RESEND_FROM_EMAIL=noreply@yourdomain.com

# --- Razorpay payments — razorpay.com/dashboard ------------
# RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
# RAZORPAY_KEY_SECRET=your-razorpay-key-secret
# RAZORPAY_WEBHOOK_SECRET=your-webhook-secret

# --- Admin panel (required for /admin) ----------------------
# Choose strong values — these protect the operator admin panel
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=change-me-to-a-strong-password
# ADMIN_SECRET=64-char-random-hex-for-cookie-signing

# --- Cron jobs (required for recurring invoices + backups) --
# Set the same value in Vercel → Settings → Environment Variables
# and in the Vercel cron Authorization header
# CRON_SECRET=your-cron-secret-token

# --- Google Drive backup ------------------------------------
# console.cloud.google.com → create project → enable Drive API →
# OAuth 2.0 credentials (Web) → add redirect URI:
# https://YOUR-DOMAIN/api/backup/google/callback
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret

# Encryption key for stored OAuth tokens (32 bytes = 64 hex chars)
# Generate with: openssl rand -hex 32
# BACKUP_ENCRYPTION_KEY=your-64-hex-char-key

# --- AI Assistant (Anthropic Claude) ------------------------
# platform.anthropic.com → API Keys
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# --- Error monitoring (Sentry) — sentry.io -----------------
# NEXT_PUBLIC_SENTRY_DSN=https://xxxx@oXXXXX.ingest.sentry.io/YYYYYYY
# SENTRY_ORG=your-sentry-org-slug
# SENTRY_PROJECT=your-sentry-project-slug
# SENTRY_AUTH_TOKEN=sntrys_your_auth_token  # only needed for source map upload
